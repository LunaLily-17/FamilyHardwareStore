<Window x:Class="HardwareStore.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="မိသားစု ဟာ့ဒ်ဝဲဆိုင်"
        Height="760"
        Width="1240"
        WindowStartupLocation="CenterScreen"
        Background="#F4F0E8">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#3B2818" Padding="20">
            <StackPanel>
                <TextBlock Text="မိသားစု"
                           Foreground="#D3B48E"
                           FontSize="12"
                           TextWrapping="Wrap"/>
                <TextBlock Text="ဟာ့ဒ်ဝဲဆိုင်"
                           Foreground="#FFF4E5"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,4,0,18"/>

                <Button Content="ပင်မစာမျက်နှာ" Margin="0,0,0,10" Height="40"/>
                <Button Content="ပစ္စည်းများ" Margin="0,0,0,10" Height="40"/>
                <Button Content="အရောင်း / POS" Margin="0,0,0,10" Height="40"/>
                <Button Content="ဘောင်ချာများ" Margin="0,0,0,10" Height="40"/>
                <Button Content="အစီရင်ခံစာများ" Margin="0,0,0,10" Height="40"/>
                <Button x:Name="AdminModulesButton" Content="စီမံခန့်ခွဲမှု" Margin="0,0,0,10" Height="40" Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock Text="{Binding WelcomeText}" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="{Binding StatusText}" Foreground="#74624D" Margin="0,6,0,0"/>
            </StackPanel>

            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,18">
                <Border Margin="0,0,10,0" Background="#FFF9F2" CornerRadius="18" Padding="18">
                    <StackPanel>
                        <TextBlock Text="ယနေ့အရောင်းအရေအတွက်" Foreground="#74624D"/>
                        <TextBlock Text="{Binding DailySales.SaleCount}" FontSize="30" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,10,0" Background="#FFF9F2" CornerRadius="18" Padding="18">
                    <StackPanel>
                        <TextBlock Text="စုစုပေါင်း ရောင်းအား" Foreground="#74624D"/>
                        <TextBlock Text="{Binding DailySales.NetSales, StringFormat=C}" FontSize="30" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFF9F2" CornerRadius="18" Padding="18">
                    <StackPanel>
                        <TextBlock Text="ပစ္စည်းများ" Foreground="#74624D"/>
                        <TextBlock Text="{Binding Products.Count}" FontSize="30" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Background="#FFF9F2" CornerRadius="18" Padding="16" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="ပစ္စည်းစာရင်း" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding Products}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ပစ္စည်းအမည်" Binding="{Binding Name}"/>
                            <DataGridTextColumn Header="မြန်မာအမည်" Binding="{Binding NameMm}"/>
                            <DataGridTextColumn Header="ပစ္စည်းကုဒ်" Binding="{Binding Sku}"/>
                            <DataGridTextColumn Header="အမျိုးအစား" Binding="{Binding CategoryName}"/>
                            <DataGridTextColumn Header="ရောင်းဈေး" Binding="{Binding SalePrice, StringFormat=C}"/>
                            <DataGridTextColumn Header="လက်ကျန်" Binding="{Binding StockOnHand}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Background="#FFF9F2" CornerRadius="18" Padding="16">
                <StackPanel>
                    <TextBlock Text="လက်ရှိလက်ကျန်" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding StockItems}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ပစ္စည်း" Binding="{Binding ProductName}"/>
                            <DataGridTextColumn Header="မြန်မာအမည်" Binding="{Binding ProductNameMm}"/>
                            <DataGridTextColumn Header="အမျိုးအစား" Binding="{Binding CategoryName}"/>
                            <DataGridTextColumn Header="လက်ကျန်" Binding="{Binding StockOnHand}"/>
                            <DataGridTextColumn Header="ပြန်ဖြည့်ရန်အဆင့်" Binding="{Binding ReorderLevel}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
