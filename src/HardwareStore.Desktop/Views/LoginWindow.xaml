<Window x:Class="HardwareStore.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="မိသားစု ဟာ့ဒ်ဝဲဆိုင်"
        Height="420"
        Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F0E8">
    <Grid Margin="28">
        <Border Background="#FFF9F2"
                BorderBrush="#D8C2A8"
                BorderThickness="1"
                CornerRadius="22"
                Padding="24">
            <StackPanel>
                <TextBlock Text="မိသားစု ဟာ့ဒ်ဝဲဆိုင်"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>
                <TextBlock Text="တစ်လုံးတည်းသုံး ဆိုင်ကွန်ပျူတာအတွက် desktop စနစ်"
                           Foreground="#74624D"
                           Margin="0,0,0,20"/>

                <TextBlock Text="အသုံးပြုသူအမည်"/>
                <TextBox x:Name="UsernameTextBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,8,0,14"
                         Height="34"/>

                <TextBlock Text="လျှို့ဝှက်နံပါတ်"/>
                <PasswordBox x:Name="PasswordInput"
                             Margin="0,8,0,14"
                             Height="34"
                             PasswordChanged="PasswordInput_OnPasswordChanged"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#9A3121"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14"/>

                <Button Content="ဝင်မည်"
                        Height="42"
                        Click="SignIn_OnClick"
                        Background="#BF5A2B"
                        Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
