@page
@model HardwareStore.Web.Pages.Categories.CreateModel
@{
    ViewData["Title"] = "အမျိုးအစားအသစ်";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>အမျိုးအစားအသစ်</h2>
            <p class="muted">ပစ္စည်းများကို အုပ်စုလိုက် စီရန် အသုံးပြုပါ။</p>
        </div>
    </div>
    <form method="post" class="form-grid">
        <div class="field">
            <label asp-for="Input.Name"></label>
            <input asp-for="Input.Name" />
        </div>
        <div class="field">
            <label asp-for="Input.NameMm"></label>
            <input asp-for="Input.NameMm" class="mm-text" />
        </div>
        <div class="field" style="grid-column: 1 / -1;">
            <label asp-for="Input.Description"></label>
            <textarea asp-for="Input.Description"></textarea>
        </div>
        <div class="field">
            <label>
                <input asp-for="Input.IsActive" type="checkbox" />
                အသုံးပြုနေ
            </label>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <p class="error-text" style="grid-column: 1 / -1;">@Model.ErrorMessage</p>
        }
        <div style="grid-column: 1 / -1;">
            <button type="submit">သိမ်းမည်</button>
        </div>
    </form>
</section>
