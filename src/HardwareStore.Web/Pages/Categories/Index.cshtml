@page
@model HardwareStore.Web.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "အမျိုးအစားများ";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>အမျိုးအစားစာရင်း</h2>
            <p class="muted">ပစ္စည်းအုပ်စုများကို စီမံနိုင်ပါသည်။</p>
        </div>
        <a class="button" asp-page="/Categories/Create">အသစ်ထည့်မည်</a>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>အမည်</th>
                <th>အသေးစိတ်</th>
                <th>အသုံးပြုနေ</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var category in Model.Categories)
        {
            <tr>
                <td>
                    <div>@category.Name</div>
                    @if (!string.IsNullOrWhiteSpace(category.NameMm))
                    {
                        <div class="mm-text muted">@category.NameMm</div>
                    }
                </td>
                <td>@category.Description</td>
                <td>@(category.IsActive ? "Yes" : "No")</td>
            </tr>
        }
        </tbody>
    </table>
</section>
