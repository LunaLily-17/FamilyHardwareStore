@page
@model HardwareStore.Web.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "ဆိုင်အချက်အလက်";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>ဆိုင်အချက်အလက်</h2>
            <p class="muted">ဘောင်ချာနှင့် အစီရင်ခံစာများတွင် အသုံးပြုသော အချက်အလက်များဖြစ်ပါသည်။</p>
        </div>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>အမည်</th>
                <th>တန်ဖိုး</th>
                <th>အသေးစိတ်</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var setting in Model.Settings)
        {
            <tr>
                <td>@setting.Key</td>
                <td>@setting.Value</td>
                <td>@setting.Description</td>
            </tr>
        }
        </tbody>
    </table>
</section>
