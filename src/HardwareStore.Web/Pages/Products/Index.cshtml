@page
@model HardwareStore.Web.Pages.Products.IndexModel
@{
    ViewData["Title"] = "ပစ္စည်းများ";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>ပစ္စည်းစာရင်း</h2>
            <p class="muted">ပစ္စည်းအမည်၊ ဈေးနှုန်း၊ ဘားကုဒ်နှင့် လက်ကျန်ကို ကြည့်နိုင်ပါသည်။</p>
        </div>
        <a class="button" asp-page="/Products/Create">ပစ္စည်းထည့်မည်</a>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>ပစ္စည်းအမည်</th>
                <th>ပစ္စည်းကုဒ်</th>
                <th>အမျိုးအစား</th>
                <th>အတိုင်းအတာ</th>
                <th>ရောင်းဈေး</th>
                <th>လက်ကျန်</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var product in Model.Products)
        {
            <tr>
                <td>
                    <div>@product.Name</div>
                    @if (!string.IsNullOrWhiteSpace(product.NameMm))
                    {
                        <div class="mm-text muted">@product.NameMm</div>
                    }
                </td>
                <td>@product.Sku</td>
                <td>
                    <div>@product.CategoryName</div>
                    @if (!string.IsNullOrWhiteSpace(product.CategoryNameMm))
                    {
                        <div class="mm-text muted">@product.CategoryNameMm</div>
                    }
                </td>
                <td>@product.UnitType</td>
                <td>@product.SalePrice.ToString("C")</td>
                <td>@product.StockOnHand</td>
                <td><a asp-page="/Products/Edit" asp-route-id="@product.Id">ပြင်မည်</a></td>
            </tr>
        }
        </tbody>
    </table>
</section>
