@page
@model HardwareStore.Web.Pages.Suppliers.IndexModel
@{
    ViewData["Title"] = "ပေးသွင်းသူများ";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>ပေးသွင်းသူစာရင်း</h2>
            <p class="muted">ဝယ်ယူမှုနှင့် ပေးသွင်းသူ အချက်အလက်များကို စီမံနိုင်ပါသည်။</p>
        </div>
        <a class="button" asp-page="/Suppliers/Create">အသစ်ထည့်မည်</a>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>အမည်</th>
                <th>ဆက်သွယ်ရမည့်သူ</th>
                <th>ဖုန်း</th>
                <th>အီးမေးလ်</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var supplier in Model.Suppliers)
        {
            <tr>
                <td>@supplier.Name</td>
                <td>@supplier.ContactPerson</td>
                <td>@supplier.Phone</td>
                <td>@supplier.Email</td>
            </tr>
        }
        </tbody>
    </table>
</section>
