@page
@model HardwareStore.Web.Pages.Suppliers.CreateModel
@{
    ViewData["Title"] = "ပေးသွင်းသူအသစ်";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>ပေးသွင်းသူအသစ်</h2>
            <p class="muted">ပေးသွင်းသူ အချက်အလက်အသစ် ထည့်ပါ။</p>
        </div>
    </div>
    <form method="post" class="form-grid">
        <div class="field">
            <label asp-for="Input.Name"></label>
            <input asp-for="Input.Name" />
        </div>
        <div class="field">
            <label asp-for="Input.ContactPerson"></label>
            <input asp-for="Input.ContactPerson" />
        </div>
        <div class="field">
            <label asp-for="Input.Phone"></label>
            <input asp-for="Input.Phone" />
        </div>
        <div class="field">
            <label asp-for="Input.Email"></label>
            <input asp-for="Input.Email" />
        </div>
        <div class="field" style="grid-column: 1 / -1;">
            <label asp-for="Input.Address"></label>
            <textarea asp-for="Input.Address"></textarea>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <p class="error-text" style="grid-column: 1 / -1;">@Model.ErrorMessage</p>
        }
        <div style="grid-column: 1 / -1;">
            <button type="submit">သိမ်းမည်</button>
        </div>
    </form>
</section>
