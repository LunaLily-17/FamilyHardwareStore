@page
@model HardwareStore.Web.Pages.Purchases.IndexModel
@{
    ViewData["Title"] = "အဝယ်စာရင်း";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>အဝယ်စာရင်း</h2>
            <p class="muted">ပစ္စည်းဝယ်ယူမှုများနှင့် လက်ခံရရှိမှုကို ကြည့်နိုင်ပါသည်။</p>
        </div>
        <a class="button" asp-page="/Purchases/Create">အဝယ်အသစ်</a>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>နံပါတ်</th>
                <th>ပေးသွင်းသူ</th>
                <th>နေ့စွဲ</th>
                <th>အခြေအနေ</th>
                <th>စုစုပေါင်း</th>
                <th>ပစ္စည်းအရေအတွက်</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var purchase in Model.Purchases)
        {
            <tr>
                <td><a asp-page="/Purchases/Details" asp-route-id="@purchase.Id">@purchase.PurchaseNumber</a></td>
                <td>@purchase.SupplierName</td>
                <td>@purchase.PurchaseDateUtc.ToLocalTime()</td>
                <td>@purchase.Status</td>
                <td>@purchase.TotalAmount.ToString("C")</td>
                <td>@purchase.ItemCount</td>
            </tr>
        }
        </tbody>
    </table>
</section>
