@page "{id:guid}"
@model HardwareStore.Web.Pages.Purchases.DetailsModel
@{
    ViewData["Title"] = "အဝယ်အသေးစိတ်";
}

<section class="panel">
    @if (Model.Purchase is null)
    {
        <h2>အဝယ်စာရင်း မတွေ့ပါ</h2>
    }
    else
    {
        <div class="panel-header">
            <div>
                <h2>@Model.Purchase.PurchaseNumber</h2>
                <p class="muted">@Model.Purchase.SupplierName</p>
            </div>
        </div>
        <table class="table">
            <tbody>
                <tr><th>နေ့စွဲ</th><td>@Model.Purchase.PurchaseDateUtc.ToLocalTime()</td></tr>
                <tr><th>အခြေအနေ</th><td>@Model.Purchase.Status</td></tr>
                <tr><th>မူလစုစုပေါင်း</th><td>@Model.Purchase.Subtotal.ToString("C")</td></tr>
                <tr><th>အခွန်</th><td>@Model.Purchase.TaxAmount.ToString("C")</td></tr>
                <tr><th>စုစုပေါင်း</th><td>@Model.Purchase.TotalAmount.ToString("C")</td></tr>
                <tr><th>မှတ်ချက်</th><td>@Model.Purchase.Notes</td></tr>
            </tbody>
        </table>

        <h3>ပစ္စည်းများ</h3>
        <table class="table">
            <thead>
                <tr>
                    <th>ပစ္စည်း</th>
                    <th>အရေအတွက်</th>
                    <th>တစ်ခုဈေး</th>
                    <th>စုစုပေါင်း</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var line in Model.Purchase.Items)
            {
                <tr>
                    <td>@line.ProductName</td>
                    <td>@line.Quantity</td>
                    <td>@line.UnitCost.ToString("C")</td>
                    <td>@line.LineTotal.ToString("C")</td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>
