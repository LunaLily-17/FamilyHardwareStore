<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - မိသားစု ဟာ့ဒ်ဝဲဆိုင်</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <a class="brand-mark" asp-page="/Index">
                <span class="brand-kicker">မိသားစု</span>
                <strong>ဟာ့ဒ်ဝဲဆိုင်</strong>
            </a>
            <nav class="nav-stack">
                <a asp-page="/Index">ပင်မစာမျက်နှာ</a>
                <a asp-page="/Products/Index">ပစ္စည်းများ</a>
                <a asp-page="/Sales/New">အရောင်း</a>
                <a asp-page="/Sales/Reprint">ဘောင်ချာ ပြန်ထုတ်ရန်</a>
                <a asp-page="/Reports/DailySales">အစီရင်ခံစာ</a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-page="/Categories/Index">အမျိုးအစားများ</a>
                    <a asp-page="/Suppliers/Index">ပေးသွင်းသူများ</a>
                    <a asp-page="/Purchases/Index">အဝယ်စာရင်း</a>
                    <a asp-page="/Settings/Index">ဆိုင်အချက်အလက်</a>
                    <a asp-page="/Backup/Index">ဒေတာ အရန်သိမ်းရန်</a>
                }
            </nav>
        </aside>
        <div class="main-shell">
            <header class="topbar">
                <div>
                    <p class="topbar-label">ဆိုင်သုံး စနစ်</p>
                    <h1>@ViewData["Title"]</h1>
                </div>
                <div class="topbar-user">
                    <span>@User.Identity?.Name</span>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <form method="post" asp-page="/Account/Logout">
                            <button type="submit" class="button secondary">ထွက်မည်</button>
                        </form>
                    }
                </div>
            </header>
            <main class="content-shell">
                @RenderBody()
            </main>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
