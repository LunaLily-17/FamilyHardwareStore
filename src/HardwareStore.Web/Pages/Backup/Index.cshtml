@page
@model HardwareStore.Web.Pages.Backup.IndexModel
@{
    ViewData["Title"] = "ဒေတာ အရန်သိမ်းရန်";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>ဒေတာ အရန်သိမ်းရန်</h2>
            <p class="muted">SQLite ဒေတာဖိုင်ကို အရန်သိမ်းနိုင်ပါသည်။</p>
        </div>
        <form method="post">
            <button type="submit">အရန်သိမ်းမည်</button>
        </form>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <p>@Model.StatusMessage</p>
    }
    <table class="table">
        <thead>
            <tr>
                <th>ဖိုင်</th>
                <th>သိမ်းထားသည့်အချိန်</th>
                <th>ဖိုင်အရွယ်အစား</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Backups)
        {
            <tr>
                <td>@item.FileName</td>
                <td>@item.CreatedUtc.ToLocalTime()</td>
                <td>@item.SizeBytes</td>
            </tr>
        }
        </tbody>
    </table>
</section>
