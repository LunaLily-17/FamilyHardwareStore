@page
@model HardwareStore.Web.Pages.Sales.NewModel
@{
    ViewData["Title"] = "အရောင်း";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>အရောင်းအသစ်</h2>
            <p class="muted">အရောင်းပြီးလျှင် ဘောင်ချာကို တိုက်ရိုက်ထုတ်နိုင်ပါသည်။</p>
        </div>
    </div>
    <form method="post" class="form-grid">
        <div class="field">
            <label asp-for="Input.ProductId"></label>
            <select asp-for="Input.ProductId" asp-items="Model.ProductOptions"></select>
        </div>
        <div class="field">
            <label asp-for="Input.Quantity"></label>
            <input asp-for="Input.Quantity" />
        </div>
        <div class="field">
            <label asp-for="Input.PaymentMethod"></label>
            <select asp-for="Input.PaymentMethod" asp-items="Html.GetEnumSelectList<HardwareStore.Domain.Enums.PaymentMethod>()"></select>
        </div>
        <div class="field">
            <label asp-for="Input.DiscountAmount"></label>
            <input asp-for="Input.DiscountAmount" />
        </div>
        <div class="field">
            <label asp-for="Input.TaxAmount"></label>
            <input asp-for="Input.TaxAmount" />
        </div>
        <div class="field" style="grid-column: 1 / -1;">
            <label asp-for="Input.Notes"></label>
            <textarea asp-for="Input.Notes"></textarea>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <p class="error-text" style="grid-column: 1 / -1;">@Model.ErrorMessage</p>
        }
        <div style="grid-column: 1 / -1;">
            <button type="submit">ရောင်းမည်</button>
        </div>
    </form>
</section>
