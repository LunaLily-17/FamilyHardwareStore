@page "{receiptNumber}"
@model HardwareStore.Web.Pages.Sales.ReceiptModel
@{
    ViewData["Title"] = "ဘောင်ချာ";
}

@if (Model.Receipt is null)
{
    <section class="panel">
        <h2>ဘောင်ချာ မတွေ့ပါ</h2>
    </section>
}
else
{
    <section class="panel receipt-card">
        <div class="panel-header no-print">
            <div>
                <h2>ဘောင်ချာ @Model.Receipt.ReceiptNumber</h2>
                <p class="muted">အရောင်းပြီးပါပြီ။ ဘောင်ချာကို တိုက်ရိုက်ထုတ်နိုင်ပါသည်။</p>
            </div>
            <div class="topbar-user">
                <button type="button" onclick="window.print()">ဘောင်ချာထုတ်မည်</button>
            </div>
        </div>

        <div class="receipt-sheet">
            <div class="receipt-header">
                <h2>@Model.ShopName</h2>
                @if (!string.IsNullOrWhiteSpace(Model.ShopNameMm))
                {
                    <p class="mm-text">@Model.ShopNameMm</p>
                }
                <p>@Model.ShopAddress</p>
                <p>@Model.ShopPhone</p>
            </div>

            <div class="receipt-meta">
                <p>ဘောင်ချာနံပါတ်: @Model.Receipt.ReceiptNumber</p>
                <p>နေ့စွဲ: @Model.Receipt.SaleDateUtc.ToLocalTime()</p>
                <p>ငွေရှင်းသူ: @Model.Receipt.CashierName</p>
            </div>

            <table class="table receipt-table">
                <thead>
                    <tr>
                        <th>ပစ္စည်း</th>
                        <th>အရေအတွက်</th>
                        <th>ဈေးနှုန်း</th>
                        <th>စုစုပေါင်း</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var line in Model.Receipt.Items)
                {
                    <tr>
                        <td>
                            <div>@line.ProductName</div>
                            @if (!string.IsNullOrWhiteSpace(line.ProductNameMm))
                            {
                                <div class="mm-text muted">@line.ProductNameMm</div>
                            }
                        </td>
                        <td>@line.Quantity</td>
                        <td>@line.UnitPrice.ToString("C")</td>
                        <td>@line.LineTotal.ToString("C")</td>
                    </tr>
                }
                </tbody>
            </table>

            <div class="receipt-total">
                <strong>စုစုပေါင်း: @Model.Receipt.TotalAmount.ToString("C")</strong>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ReceiptFooter))
            {
                <p class="receipt-footer">@Model.ReceiptFooter</p>
            }
        </div>
    </section>
}

@section Scripts {
    @if (Model.AutoPrint && Model.Receipt is not null)
    {
        <script>
            window.addEventListener("load", function () {
                setTimeout(function () { window.print(); }, 300);
            });
        </script>
    }
}
