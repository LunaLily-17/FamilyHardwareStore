@page
@model HardwareStore.Web.Pages.Sales.ReprintModel
@{
    ViewData["Title"] = "ဘောင်ချာ ပြန်ထုတ်ရန်";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>ဘောင်ချာ ပြန်ထုတ်ရန်</h2>
            <p class="muted">ဘောင်ချာနံပါတ်ဖြင့် ရှာပြီး ပြန်ထုတ်နိုင်ပါသည်။</p>
        </div>
    </div>
    <form method="post" class="form-grid">
        <div class="field">
            <label asp-for="ReceiptNumber"></label>
            <input asp-for="ReceiptNumber" />
        </div>
        <div style="align-self: end;">
            <button type="submit">ရှာမည်</button>
        </div>
    </form>
</section>
