@page
@model HardwareStore.Web.Pages.Reports.DailySalesModel
@{
    ViewData["Title"] = "Daily Sales Report";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>Daily sales summary</h2>
            <p class="muted">Print-friendly HTML report foundation with date filtering.</p>
        </div>
    </div>

    <form method="get" class="form-grid" style="margin-bottom: 1rem;">
        <div class="field">
            <label asp-for="Date"></label>
            <input asp-for="Date" type="date" />
        </div>
        <div style="align-self: end;">
            <button type="submit">Run report</button>
        </div>
    </form>

    <table class="table">
        <tbody>
            <tr><th>Date</th><td>@Model.Report.Date</td></tr>
            <tr><th>Sales count</th><td>@Model.Report.SaleCount</td></tr>
            <tr><th>Gross sales</th><td>@Model.Report.GrossSales.ToString("C")</td></tr>
            <tr><th>Discounts</th><td>@Model.Report.DiscountAmount.ToString("C")</td></tr>
            <tr><th>Tax</th><td>@Model.Report.TaxAmount.ToString("C")</td></tr>
            <tr><th>Net sales</th><td>@Model.Report.NetSales.ToString("C")</td></tr>
        </tbody>
    </table>
</section>
