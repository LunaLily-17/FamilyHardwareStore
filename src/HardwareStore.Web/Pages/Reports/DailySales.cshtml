@page
@model HardwareStore.Web.Pages.Reports.DailySalesModel
@{
    ViewData["Title"] = "နေ့စဉ် အရောင်းအစီရင်ခံစာ";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>နေ့စဉ် အရောင်းအစီရင်ခံစာ</h2>
            <p class="muted">နေ့စွဲရွေးပြီး အရောင်းစာရင်းကို ကြည့်နိုင်ပါသည်။</p>
        </div>
    </div>

    <form method="get" class="form-grid" style="margin-bottom: 1rem;">
        <div class="field">
            <label asp-for="Date"></label>
            <input asp-for="Date" type="date" />
        </div>
        <div style="align-self: end;">
            <button type="submit">ကြည့်မည်</button>
        </div>
    </form>

    <table class="table">
        <tbody>
            <tr><th>နေ့စွဲ</th><td>@Model.Report.Date</td></tr>
            <tr><th>အရောင်းအရေအတွက်</th><td>@Model.Report.SaleCount</td></tr>
            <tr><th>မူလရောင်းအား</th><td>@Model.Report.GrossSales.ToString("C")</td></tr>
            <tr><th>လျှော့ဈေး</th><td>@Model.Report.DiscountAmount.ToString("C")</td></tr>
            <tr><th>အခွန်</th><td>@Model.Report.TaxAmount.ToString("C")</td></tr>
            <tr><th>စုစုပေါင်း ရောင်းအား</th><td>@Model.Report.NetSales.ToString("C")</td></tr>
        </tbody>
    </table>
</section>
